  m_Script: {fileID: 11500000, guid: bedae6e930e9d1d4a8766f294f91fc97, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ConversationTrigger2D
  dialogueLines:
  - text: I think I am actually going insane
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Is this real? Am I really in the hospital?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Who am I really?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Who is the real me?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Still, I gotta get out before having this identity crisis
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  triggerOnlyOnce: 1
  triggerID: Hospital
