  dialogueLines:
  - text: Yo yall know what
    characterSprite: {fileID: -3680286530704523052, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: IM FK tired of baba
    characterSprite: {fileID: -3680286530704523052, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Why is it the protagonist
    characterSprite: {fileID: -3680286530704523052, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: I am the real protagonist!!
    characterSprite: {fileID: -3680286530704523052, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: I thought KEKE is my friend
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: It must be a dream
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  triggerOnlyOnce: 1
  triggerID: Main2
