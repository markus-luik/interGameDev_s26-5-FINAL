  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bedae6e930e9d1d4a8766f294f91fc97, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ConversationTrigger2D
  dialogueLines:
  - text: Why is everything so weird
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Is this a lucid dream?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Who am I? What am I doing here?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: I can't hold myself anymore!
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Let me get out of here!
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  triggerOnlyOnce: 1
  triggerID: Main1
