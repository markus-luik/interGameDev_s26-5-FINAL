  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ConversationTrigger2D
  dialogueLines:
  - text: Where am I?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Thought I was in Miami for holiday
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Didn't I js beat "BABA is you"?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Oh no, I am Baba
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: For now
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  - text: Wait KEKE is that you?
    characterSprite: {fileID: -8828824254825895988, guid: 3546a85900f62fc4894d2bc60eca1a45, type: 3}
  triggerOnlyOnce: 1
  triggerID: 
